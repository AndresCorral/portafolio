---
import DigitCounter from './DigitCounter.astro';
const t = Astro.props.t;
---

<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content container">
    <div class="hero-text">
      <DigitCounter />
      <h1 class="hero-name">Andrés Corral</h1>
      <p class="hero-subtitle">{t['hero.subtitle']}</p>
      <p class="hero-tagline">{t['hero.tagline']}</p>
      <div class="hero-cta">
        <a href="#projects" class="btn">{t['nav.projects']} ↓</a>
      </div>
    </div>
    <div class="hero-image">
      <div class="hero-image-frame">
        <img src="/images/profile.png" alt="Andrés Corral" class="hero-img" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    position: relative;
    padding-top: var(--nav-height);
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(147, 51, 234, 0.06) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 20%, rgba(110, 231, 183, 0.03) 0%, transparent 50%),
      radial-gradient(ellipse at 20% 80%, rgba(110, 231, 183, 0.02) 0%, transparent 50%);
    pointer-events: none;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 80px;
    align-items: center;
  }
  .hero-text {
    max-width: 700px;
  }
  .hero-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-image-frame {
    position: relative;
    width: 600px;
    height: 600px;
    max-width: 100%;
    overflow: hidden;
  }
  .hero-image-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 80px 30px var(--color-bg);
    z-index: 2;
    pointer-events: none;
  }
  .hero-image-frame::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -10%;
    right: -10%;
    height: 50%;
    background: linear-gradient(to bottom, transparent 0%, var(--color-bg) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(48px, 10vw, 140px);
    font-weight: 400;
    line-height: 1;
    margin: 24px 0 16px;
    color: var(--color-text);
  }
  .hero-subtitle {
    font-size: clamp(14px, 2vw, 18px);
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 16px;
  }
  .hero-tagline {
    font-size: clamp(13px, 1.5vw, 15px);
    color: var(--color-muted-strong);
    line-height: 1.6;
    max-width: 600px;
    margin-bottom: 40px;
  }
  .hero-cta {
    display: flex;
    gap: 16px;
  }
  @media (max-width: 1024px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .hero-image {
      justify-content: center;
    }
    .hero-image-frame {
      width: min(460px, 92vw);
      height: min(460px, 92vw);
    }
    .hero-tagline {
      margin-bottom: 24px;
    }
  }
</style>
