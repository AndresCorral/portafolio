---
const t = Astro.props.t;
const lang = Astro.currentLocale || 'en';
---

<section class="about" id="about">
  <div class="container">
    <span class="section-label">{t['nav.about']}</span>
    <h2 class="section-title">{t['about.title']}</h2>
    <div class="about-grid">
      <div class="about-text">
        <p class="about-description">{t['about.description']}</p>
        <div class="about-cta">
          <a href={lang === 'es' ? '/files/CV_Andres_Corral_ES.pdf' : '/files/CV_Andres_Corral_EN.pdf'} class="btn" download>
            ↓ {t['about.downloadCv']}
          </a>
        </div>
      </div>
      <div class="about-skills">
        <div class="skill-group">
          <h3 class="skill-label">Orchestration</h3>
          <div class="skill-tags">
            <span>n8n</span><span>Make</span><span>Zapier</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">LLMs & Agents</h3>
          <div class="skill-tags">
            <span>Claude</span><span>Gemini</span><span>GPT-4</span><span>LangChain</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">Context Engineering</h3>
          <div class="skill-tags">
            <span>RAG</span><span>Pinecone</span><span>Embeddings</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">APIs</h3>
          <div class="skill-tags">
            <span>WhatsApp Business</span><span>LinkedIn API</span><span>Gmail</span><span>Odoo</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">Databases</h3>
          <div class="skill-tags">
            <span>NocoDB</span><span>Airtable</span><span>PostgreSQL</span><span>Supabase</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">Development</h3>
          <div class="skill-tags">
            <span>Python</span><span>FastAPI</span><span>TypeScript</span><span>SQL</span>
          </div>
        </div>
        <div class="skill-group">
          <h3 class="skill-label">Observability</h3>
          <div class="skill-tags">
            <span>Langfuse</span><span>PostHog</span><span>Docker</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 120px 0;
    border-top: 1px solid var(--color-border);
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
  }
  .about-description {
    font-size: 15px;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 32px;
  }
  .about-cta {
    display: flex;
    gap: 12px;
  }
  .skill-group {
    margin-bottom: 20px;
  }
  .skill-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 8px;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .skill-tags span {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
  @media (max-width: 768px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
  }
</style>
