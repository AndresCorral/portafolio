---
const { project, index, lang } = Astro.props;
const content = project[lang];
const prefix = lang === 'es' ? '/es' : '';
---

<a href={prefix + '/projects/' + project.slug} class="project-card">
  <div class="project-index">{String(index + 1).padStart(2, '0')}</div>
  <div class="project-info">
    <h2 class="project-title">{content.title}</h2>
    <p class="project-desc">{content.description}</p>
    <div class="project-meta">
      <span class="project-year">{project.year}</span>
      <span class="project-role">{project.role[lang]}</span>
    </div>
    <div class="project-stack">
      {project.stack.slice(0, 4).map(s => <span class="stack-tag">{s}</span>)}
      {project.stack.length > 4 && <span class="stack-tag">+{project.stack.length - 4}</span>}
    </div>
  </div>
  <div class="project-arrow">→</div>
</a>

<style>
  .project-card {
    display: grid;
    grid-template-columns: 48px 1fr 32px;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
    align-items: start;
  }
  .project-card:last-child {
    border-bottom: none;
  }
  .project-card:hover {
    padding-left: 12px;
  }
  .project-card:hover .project-title {
    color: var(--color-accent);
  }
  .project-card:hover .project-arrow {
    transform: translateX(4px);
    color: var(--color-accent);
  }
  .project-index {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted);
    padding-top: 4px;
  }
  .project-info {
    min-width: 0;
  }
  .project-title {
    font-family: var(--font-heading);
    font-size: clamp(24px, 4vw, 48px);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 8px;
    transition: color 0.3s ease;
  }
  .project-desc {
    font-size: 13px;
    color: var(--color-muted);
    line-height: 1.5;
    margin-bottom: 12px;
  }
  .project-meta {
    display: flex;
    gap: 16px;
    margin-bottom: 12px;
  }
  .project-year {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-muted-strong);
  }
  .project-role {
    font-size: 11px;
    color: var(--color-muted-strong);
  }
  .project-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .stack-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 2px 8px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .project-arrow {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--color-muted-strong);
    transition: all 0.3s ease;
    padding-top: 4px;
  }
</style>
