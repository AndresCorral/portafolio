---
const t = Astro.props.t;
const currentLang = Astro.props.lang || 'en';
const prefix = currentLang === 'es' ? '/es' : '';
---

<nav class="nav">
  <div class="nav-inner container">
    <a href={prefix + '/'} class="nav-logo">AC</a>
    <div class="nav-desktop-links">
      <button class="nav-link" data-section="projects">{t['nav.projects']}</button>
      <button class="nav-link" data-section="about">{t['nav.about']}</button>
      <button class="nav-link" data-section="contact">{t['nav.contact']}</button>
      <a href={currentLang === 'es' ? '/es' : '/'} class="lang-link">
        <span class:list={{ active: currentLang === 'en' }}>EN</span>
        <span class="sep">/</span>
        <span class:list={{ active: currentLang === 'es' }}>ES</span>
      </a>
    </div>
    <a href={currentLang === 'es' ? '/es' : '/'} class="lang-link mobile-lang-nav">
      <span class:list={{ active: currentLang === 'en' }}>EN</span>
      <span class="sep">/</span>
      <span class:list={{ active: currentLang === 'es' }}>ES</span>
    </a>
    <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>
  </div>
</nav>

<div class="drawer-overlay" id="drawer-overlay"></div>

<div class="drawer" id="drawer">
  <div class="drawer-handle"></div>
  <div class="drawer-content">
    <div class="drawer-links">
      <button class="drawer-link" data-section="projects">{t['nav.projects']}</button>
      <button class="drawer-link" data-section="about">{t['nav.about']}</button>
      <button class="drawer-link" data-section="contact">{t['nav.contact']}</button>
    </div>
  </div>
</div>

<div class="about-modal" id="about-modal">
  <div class="about-modal-backdrop"></div>
  <div class="about-modal-content container">
    <button class="modal-close" id="modal-close">✕</button>
    <div class="about-modal-body">
      <div class="about-modal-image">
        <div class="modal-image-frame">
          <img src="/images/profile.png" alt="Andrés Corral" class="modal-img" />
        </div>
      </div>
      <div class="about-modal-text">
        <span class="section-label">{t['nav.about']}</span>
        <h2 class="modal-title">{t['about.title']}</h2>
        <p class="modal-description">{t['about.description']}</p>
        <div class="modal-skills">
          <div class="skill-group">
            <h3 class="skill-label">Orchestration</h3>
            <div class="skill-tags"><span>n8n</span><span>Make</span><span>Zapier</span></div>
          </div>
          <div class="skill-group">
            <h3 class="skill-label">LLMs & Agents</h3>
            <div class="skill-tags"><span>Claude</span><span>Gemini</span><span>GPT-4</span><span>LangChain</span></div>
          </div>
          <div class="skill-group">
            <h3 class="skill-label">Context Engineering</h3>
            <div class="skill-tags"><span>RAG</span><span>Pinecone</span><span>Embeddings</span></div>
          </div>
          <div class="skill-group">
            <h3 class="skill-label">APIs</h3>
            <div class="skill-tags"><span>WhatsApp Business</span><span>LinkedIn API</span><span>Gmail</span><span>Odoo</span></div>
          </div>
          <div class="skill-group">
            <h3 class="skill-label">Databases</h3>
            <div class="skill-tags"><span>NocoDB</span><span>Airtable</span><span>PostgreSQL</span><span>Supabase</span></div>
          </div>
          <div class="skill-group">
            <h3 class="skill-label">Development</h3>
            <div class="skill-tags"><span>Python</span><span>FastAPI</span><span>TypeScript</span><span>SQL</span></div>
          </div>
        </div>
        <a href={currentLang === 'es' ? '/files/CV_Andres_Corral_ES.pdf' : '/files/CV_Andres_Corral_EN.pdf'} class="btn" download>
          ↓ {t['about.downloadCv']}
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const hamburger = document.getElementById('hamburger');
  const drawer = document.getElementById('drawer');
  const overlay = document.getElementById('drawer-overlay');

  function openDrawer() {
    hamburger.setAttribute('aria-expanded', 'true');
    drawer.classList.add('open');
    overlay.classList.add('open');
    document.body.classList.add('drawer-open');
  }

  function closeDrawer() {
    hamburger.setAttribute('aria-expanded', 'false');
    drawer.classList.remove('open');
    overlay.classList.remove('open');
    document.body.classList.remove('drawer-open');
  }

  if (hamburger && drawer) {
    hamburger.addEventListener('click', () => {
      const expanded = hamburger.getAttribute('aria-expanded') === 'true';
      expanded ? closeDrawer() : openDrawer();
    });

    drawer.querySelectorAll('.drawer-link').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });

    if (overlay) overlay.addEventListener('click', closeDrawer);
  }

  const aboutModal = document.getElementById('about-modal');

  function openAboutModal() {
    aboutModal.classList.add('open');
    closeDrawer();
  }

  function closeAboutModal() {
    aboutModal.classList.remove('open');
  }

  document.querySelectorAll('[data-section="about"]').forEach(btn => {
    btn.addEventListener('click', openAboutModal);
  });

  document.getElementById('modal-close')?.addEventListener('click', closeAboutModal);
  aboutModal?.addEventListener('click', (e) => {
    if (e.target === aboutModal || e.target.classList.contains('about-modal-backdrop')) closeAboutModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeAboutModal();
      closeDrawer();
    }
  });
</script>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(10, 11, 13, 0.8);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  .nav-logo {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.06em;
  }
  .nav-desktop-links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
  .nav-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
    padding: 0;
    transition: color 0.2s ease;
  }
  .nav-link:hover {
    color: var(--color-text);
  }
  .lang-link {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--color-muted);
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .lang-link:hover {
    color: var(--color-text);
  }
  .lang-link .active {
    color: var(--color-accent);
  }
  .sep {
    color: var(--color-muted-strong);
    font-size: 10px;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 28px;
    height: 28px;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 110;
    padding: 0;
  }
  .hamburger-line {
    display: block;
    width: 100%;
    height: 1.5px;
    background: var(--color-text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile-lang-nav {
    display: none;
    margin-right: 16px;
  }

  @media (max-width: 768px) {
    .nav-desktop-links {
      display: none;
    }
    .hamburger {
      display: flex;
    }
    .mobile-lang-nav {
      display: flex;
    }
  }

  .drawer-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 199;
    background: rgba(0, 0, 0, 0.6);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .drawer-overlay.open {
    opacity: 1;
  }

  .drawer {
    display: none;
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 200;
    background: #0D0E10;
    border-top: 1px solid var(--color-border);
    transform: translateY(100%);
    transition: transform 0.35s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .drawer.open {
    transform: translateY(0);
  }

  .drawer-handle {
    width: 36px;
    height: 4px;
    border-radius: 2px;
    background: var(--color-muted-strong);
    margin: 10px auto 0;
  }

  .drawer-content {
    padding: 24px 32px 40px;
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .drawer-link {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 20px;
    font-weight: 300;
    color: var(--color-text);
    padding: 8px 0;
    text-align: left;
    transition: color 0.2s ease;
  }
  .drawer-link:hover {
    color: var(--color-accent);
  }

  .drawer-lang {
    margin-top: 8px;
    font-size: 14px;
  }

  @media (max-width: 768px) {
    .drawer-overlay {
      display: block;
      pointer-events: none;
    }
    .drawer-overlay.open {
      pointer-events: auto;
    }
    .drawer {
      display: block;
    }
    body.drawer-open {
      overflow: hidden;
    }
  }

  .about-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 300;
    align-items: center;
    justify-content: center;
  }
  .about-modal.open {
    display: flex;
  }
  .about-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 11, 13, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .about-modal-content {
    position: relative;
    z-index: 1;
    max-height: 85vh;
    overflow-y: auto;
    width: 100%;
  }
  .modal-close {
    position: absolute;
    top: 0;
    right: var(--padding-h);
    background: none;
    border: none;
    color: var(--color-muted);
    font-size: 24px;
    cursor: pointer;
    z-index: 2;
    transition: color 0.2s ease;
  }
  .modal-close:hover {
    color: var(--color-text);
  }
  .about-modal-body {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 64px;
    padding: 48px 0;
    align-items: start;
  }
  .about-modal-image {
    display: flex;
    justify-content: center;
  }
  .modal-image-frame {
    width: 280px;
    height: 280px;
    overflow: hidden;
    position: relative;
  }
  .modal-image-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 60px 20px var(--color-bg);
    z-index: 2;
    pointer-events: none;
  }
  .modal-image-frame::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: -10%;
    right: -10%;
    height: 45%;
    background: linear-gradient(to bottom, transparent 0%, var(--color-bg) 100%);
    z-index: 1;
    pointer-events: none;
  }
  .modal-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    mask-image: radial-gradient(ellipse 70% 65% at 50% 40%, black 65%, transparent 100%);
    -webkit-mask-image: radial-gradient(ellipse 70% 65% at 50% 40%, black 65%, transparent 100%);
  }
  .modal-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 400;
    line-height: 1.1;
    margin: 16px 0 24px;
  }
  .modal-description {
    font-size: 14px;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: 32px;
  }
  .modal-skills {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 32px;
  }
  .skill-group {
    margin-bottom: 0;
  }
  .skill-label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-muted);
    margin-bottom: 6px;
  }
  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .skill-tags span {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    color: var(--color-muted);
  }
  @media (max-width: 768px) {
    .about-modal-body {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 32px 0;
    }
    .about-modal-image {
      display: none;
    }
    .modal-skills {
      grid-template-columns: 1fr;
    }
  }
</style>
